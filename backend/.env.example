# ============================================================
# VARIÁVEIS DE AMBIENTE - CAC LTDA
# Copie este arquivo para .env e preencha com seus valores
# NUNCA versione o .env real no git!
# ============================================================

# --- Banco de Dados ---
DB_USER=sa
DB_PASSWORD=SuaSenhaAqui
DB_HOST=localhost
DB_NAME=banco_cac
DB_PORT=1433

# --- Autenticação JWT ---
# Gere um segredo forte: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=gere_um_segredo_de_64_bytes_aqui_muito_longo_e_aleatorio
JWT_EXPIRES_IN=8h

# --- Servidor ---
PORT=3000
NODE_ENV=development

# --- CORS ---
# URL do seu front-end (ex: onde o Live Server roda)
FRONTEND_ORIGIN=http://127.0.0.1:5500
